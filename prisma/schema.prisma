generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissionType {
  QUESTION
  PROBLEM
}

enum SubmissionStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

model Submission {
  id        String           @id @default(cuid())
  type      SubmissionType
  fullName  String
  email     String
  phone     String?
  subject   String?
  location  String?
  category  String?
  message   String
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}
